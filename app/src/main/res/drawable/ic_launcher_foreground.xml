<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep backdrop drop-shadow for the glass dome -->
    <path
        android:fillColor="#40000000"
        android:pathData="M54,54m-41,2a41,41 0 1,1 82,0a41,41 0 1,1 -82,0" />

    <!-- Glass Dome Outer Rim Stroke -->
    <path
        android:pathData="M54,54m-38,0a38,38 0 1,1 76,0a38,38 0 1,1 -76,0"
        android:strokeWidth="1.5">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="32"
                android:startY="16"
                android:endX="76"
                android:endY="92"
                android:type="linear">
                <item android:offset="0.0" android:color="#E0FFFFFF" />
                <item android:offset="0.3" android:color="#33FFFFFF" />
                <item android:offset="1.0" android:color="#20000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glass Dome Fill (Refractive translucent liquid glass gradient) -->
    <path
        android:pathData="M54,54m-37,0a37,37 0 1,1 74,0a37,37 0 1,1 -74,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="17"
                android:endX="54"
                android:endY="91"
                android:type="linear">
                <item android:offset="0.0" android:color="#4DFFFFFF" />
                <item android:offset="0.4" android:color="#1AFFFFFF" />
                <item android:offset="0.8" android:color="#0D1E293B" />
                <item android:offset="1.0" android:color="#3300F0FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central Illuminated Element (Refracted behind/inside the glass) -->
    <!-- Shadow behind the central element for realistic 3D depth -->
    <path
        android:fillColor="#30000000"
        android:pathData="M54,56m-18,0a18,18 0 1,1 36,0a18,18 0 1,1 -36,0" />

    <!-- Left Book Page (Glowing Soft Cyan) -->
    <path
        android:pathData="M 52,43 C 46,42 41,44 37,46 L 37,64 C 41,62 46,60 52,61 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="37"
                android:startY="43"
                android:endX="52"
                android:endY="64"
                android:type="linear">
                <item android:offset="0.0" android:color="#8000F0FF" />
                <item android:offset="1.0" android:color="#CCFFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right Book Page (Glowing Soft Blue-Violet) -->
    <path
        android:pathData="M 56,43 C 62,42 67,44 71,46 L 71,64 C 67,62 62,60 56,61 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="56"
                android:startY="43"
                android:endX="71"
                android:endY="64"
                android:type="linear">
                <item android:offset="0.0" android:color="#807000FF" />
                <item android:offset="1.0" android:color="#CCFFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Book Spine -->
    <path
        android:fillColor="#E1F5FE"
        android:pathData="M 53,43 h 2 v 18 h -2 z" />

    <!-- Circular Revision / Sync arrows indicating Spaced Repetition -->
    <path
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M 37,54 A 17,17 0 1,1 66,66">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="34"
                android:startY="34"
                android:endX="74"
                android:endY="74"
                android:type="linear">
                <item android:offset="0.0" android:color="#00F0FF" />
                <item android:offset="1.0" android:color="#7000FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Sync Arrow Head -->
    <path
        android:fillColor="#7000FF"
        android:pathData="M 66,61 l 4,5 l -5,2 z" />

    <!-- APPLE STYLE SPECULAR HIGHLIGHT (The top liquid reflection) -->
    <path
        android:pathData="M54,20 C42,20 31,23 25,32 C30,26 42,23 54,23 C66,23 78,26 83,32 C77,23 66,20 54,20 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="20"
                android:endX="54"
                android:endY="30"
                android:type="linear">
                <item android:offset="0.0" android:color="#EEFFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Secondary Soft Elliptical Lens Reflection at Top Left -->
    <path
        android:pathData="M 32,23 C 45,21 63,22 76,23 C 71,21 57,20 44,20 C 31,20 33,22 32,23 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="44"
                android:startY="20"
                android:endX="44"
                android:endY="24"
                android:type="linear">
                <item android:offset="0.0" android:color="#C0FFFFFF" />
                <item android:offset="1.0" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom Light Refraction Rim (Apple's signature ground bounce light) -->
    <path
        android:pathData="M54,88 C40,88 28,84 21,79 C28,85 40,86 54,86 C68,86 80,85 87,79 C80,84 68,88 54,88 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="88"
                android:endX="54"
                android:endY="80"
                android:type="linear">
                <item android:offset="0.0" android:color="#8000F0FF" />
                <item android:offset="1.0" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

</vector>

